{
  "app-id": "tech.keyforge.keyforge_master",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.node24"],
  "base": "org.electronjs.Electron2.BaseApp",
  "base-version": "25.08",
  "separate-locales": false,
  "command": "start-keyforge-master.sh",
  "finish-args": [
    "--share=ipc",
    "--share=network",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=all",
    "--allow=bluetooth",
    "--filesystem=/run/udev:ro",
    "--filesystem=/sys:ro",
    "--filesystem=/run/media",
    "--filesystem=/media",
    "--system-talk-name=org.freedesktop.UDisks2",
    "--talk-name=org.freedesktop.Flatpak",
    "--env=ELECTRON_OZONE_PLATFORM_HINT=auto"
  ],
  "modules": [
    {
      "name": "keyforge-master",
      "buildsystem": "simple",
      "build-commands": [
        "mkdir -p /app/main/",
        "cp -a * /app/main/ || true",
        "install -Dm 644 tech.keyforge.keyforge_master.desktop /app/share/applications/tech.keyforge.keyforge_master.desktop",
        "install -Dm 644 tech.keyforge.keyforge_master.metainfo.xml /app/share/metainfo/tech.keyforge.keyforge_master.metainfo.xml",
        "install -Dm 755 start-keyforge-master.sh /app/bin/start-keyforge-master.sh",
        "install -Dm 755 udevadm /app/bin/udevadm",
        "install -Dm 644 icon.svg /app/share/icons/hicolor/scalable/apps/tech.keyforge.keyforge_master.svg"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://master.keyforge.tech/app-releases/flatpak/keyforge-master_2.0.0_flatpak.tar.xz",
          "sha256": "f533453b9a4f2978b3404db90ea2b9f39dc507a163a66d9ea568a267f4e5ee30"
        },
        {
          "type": "file",
          "path": "tech.keyforge.keyforge_master.metainfo.xml"
        },
        {
          "type": "file",
          "path": "icon.svg"
        },
        {
          "type": "script",
          "dest-filename": "start-keyforge-master.sh",
          "commands": [
            "zypak-wrapper.sh /app/main/Keyforge_Master_Configurator --ozone-platform-hint=auto --disable-features=VaapiVideoDecoder \"$@\""
          ]
        },
        {
          "type": "script",
          "dest-filename": "udevadm",
          "commands": [
            "exec flatpak-spawn --host udevadm \"$@\""
          ]
        }
      ]
    }
  ]
}